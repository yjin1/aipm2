# What: Example environment file for deploying the AIPM agent service.
# Purpose: Copy these values into the server-side .env used by Docker Compose.

OPENAI_API_KEY=replace-with-your-server-side-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
AIPM_PUBLIC_BASE_URL=https://semaa.site/aipm
LIBRECHAT_MONGO_URI=mongodb://mongodb:27017/LibreChat
LIBRECHAT_CONTAINER_UPLOADS_DIR=/app/uploads
LIBRECHAT_UPLOADS_DIR=/app/librechat_uploads
LIBRECHAT_UPLOADS_HOST_DIR=../LibreChat/uploads
